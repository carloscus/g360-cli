{
  "name": "flet-desktop",
  "description": "G360 Flet Migration Application",
  "framework": "flet",
  "version": "1.2.0",
  "python": ">=3.11,<4.0",
  "colors": {
    "bg": "#0b1220",
    "surface": "#1a2332",
    "accent": "#00d084",
    "text": "#f0f4f8",
    "muted": "#94a3b8",
    "success": "#22c55e",
    "warning": "#f59e0b",
    "error": "#ef4444"
  },
  "effects": {
    "glassmorphism": true,
    "blur": "12px",
    "rounded": "12px"
  },
  "signature": {
    "mode": "powered",
    "text": "powered by G360"
  },
  "build": {
    "tool": "flet",
    "target": "windows",
    "name": "G360-App"
  },
  "dependencies": {
    "flet": ">=0.25.0"
  }
}
