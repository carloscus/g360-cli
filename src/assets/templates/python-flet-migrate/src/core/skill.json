{
  "name": "flet-desktop",
  "description": "G360 Flet Desktop - Migrated",
  "framework": "flet",
  "version": "1.1.0",
  "colors": {
    "bg": "#0b1220",
    "surface": "#1a2332",
    "accent": "#00d084",
    "text": "#f0f4f8",
    "muted": "#94a3b8",
    "success": "#22c55e",
    "warning": "#f59e0b",
    "error": "#ef4444"
  },
  "effects": {
    "glassmorphism": true,
    "blur": "12px",
    "rounded": "12px"
  },
  "signature": {
    "mode": "powered",
    "text": "powered by G360"
  },
  "build": {
    "type": "portable",
    "output": "dist",
    "name": "G360-Migrated-App",
    "tool": "pyinstaller",
    "onefile": true,
    "windowed": true
  }
}
