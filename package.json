{
  "name": "g360-cli",
  "version": "1.10.0",
  "description": "CLI tool for bootstrapping G360 projects with standardized structure, assets, identity, and ERP data processing",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "g360": "src/cli.js"
  },
  "scripts": {
    "prepublishOnly": "node -e \"console.log('Use: npm install -g g360-cli')\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build": "npm run build:portable",
    "build:portable": "pkg . --targets node18-win-x64 --output dist/g360.exe",
    "postinstall": "echo '✅ g360-cli instalado. Asegúrate de tener Python 3.11+ y pip instalados.'"
  },
  "pkg": {
    "assets": [
      "src/assets/**/*",
      "py/**/*"
    ],
    "outputPath": "dist",
    "scripts": [],
    "targets": "node18-win-x64"
  },
  "keywords": [
    "g360",
    "cli",
    "scaffolding",
    "generator",
    "erp",
    "data-processing"
  ],
  "author": "Carlos Cusi",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.2",
    "ora": "^9.4.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.6",
    "pkg": "^5.8.1",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ccusi/g360-cli.git"
  }
}
