{
  "name": "g360-cli",
  "version": "1.4.0",
  "description": "CLI tool for bootstrapping G360 projects with standardized structure, assets, and identity",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "g360": "src/cli.js"
  },
  "scripts": {
    "prepublishOnly": "node -e \"console.log('Use: npm install -g g360-cli')\"",
    "test": "echo \"No tests configured\"",
    "build": "npm run build:portable",
    "build:portable": "pkg . --targets node18-win-x64 --output dist/g360.exe"
  },
  "pkg": {
    "assets": [
      "src/assets/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "g360",
    "cli",
    "scaffolding",
    "generator"
  ],
  "author": "Carlos Cusi",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.4.2",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
